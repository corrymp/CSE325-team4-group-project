@page "/login"
@using System.Net.Http.Json
@using Plan2Gather.Auth
@using Plan2Gather.Services
@inject NavigationManager Nav
@inject JwtAuthStateProvider AuthState
@inject ApiHttpClientFactory ApiFactory
@rendermode InteractiveServer

<PageTitle>Login</PageTitle>

<section class="auth-section">
    <EditForm Model="this" FormName="loginForm" OnSubmit="HandleLogin">
        <h2>Sign in to your account</h2>
        <hr />

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="text-danger" role="alert">@_error</div>
        }

        <fieldset>
            <input type="text"
                   id="username"
                   placeholder="Username"
                   @bind="_username"
                   required />
            <label for="username">Username</label>
        </fieldset>

        <fieldset>
            <input type="password"
                   id="password"
                   placeholder="Password"
                   @bind="_password"
                   required />
            <label for="password">Password</label>
        </fieldset>

        <button type="submit" disabled="@_loading">
            @(_loading ? "Signing in…" : "Log in")
        </button>

        <fieldset>
            <p>Don't have an account? <a href="/register">Register</a></p>
        </fieldset>
    </EditForm>
</section>

@code {
    private string _username = "";
    private string _password = "";
    private string _error = "";
    private bool _loading = false;

    private async Task HandleLogin()
    {
        _error = "";
        _loading = true;
        try
        {
            var client = ApiFactory.Create();
            var payload = new LoginRequest(_username, _password);
            var response = await client.PostAsJsonAsync("/api/auth/login", payload);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponse>();
                if (result is not null)
                {
                    await AuthState.SetTokenAsync(result.Token);
                    Nav.NavigateTo("/");
                }
            }
            else
            {
                _error = "Invalid username or password.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Something went wrong: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
