@page "/login"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Plan2Gather.Auth
@using Plan2Gather.Services
@inject NavigationManager Nav
@inject JwtAuthStateProvider AuthState
@inject ApiHttpClientFactory ApiFactory

<PageTitle>Login</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">Sign in to your account</h2>
                <hr />

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger" role="alert">@_error</div>
                }

                <form @onsubmit="HandleLogin" @onsubmit:preventDefault="true">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" id="username" class="form-control" placeholder="Username" @bind="_username" @bind:event="oninput" required />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" id="password" class="form-control" placeholder="Password" @bind="_password" @bind:event="oninput" required />
                    </div>

                    <button type="submit" class="btn btn-orange w-100" disabled="@_loading">
                        @(_loading ? "Signing in…" : "Log in")
                    </button>

                    <div class="text-center mt-3">
                        <p>Don't have an account? <a href="/register">Register</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@code {
    private string _username = "";
    private string _password = "";
    private string _error = "";
    private bool _loading = false;

    private async Task HandleLogin()
    {
        Console.WriteLine("HandleLogin called");
        _error = "";
        _loading = true;

        try
        {
            var client = ApiFactory.Create();
            var payload = new LoginRequest(_username, _password);
            var response = await client.PostAsJsonAsync("/api/auth/login", payload);

            Console.WriteLine($"Response status: {response.StatusCode}");

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponse>();
                if (result is not null)
                {
                    await AuthState.SetTokenAsync(result.Token);
                    Console.WriteLine("Token stored, navigating to profile");
                    Nav.NavigateTo("/profile", true); // true forces a full page reload
                }
                else
                {
                    _error = "Invalid response from server.";
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Login error: {errorContent}");
                _error = "Invalid username or password.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception: {ex.Message}");
            _error = $"Something went wrong: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}