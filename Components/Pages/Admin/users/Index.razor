@page "/users"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using Plan2Gather.Components
@using Plan2Gather.Data
@implements IAsyncDisposable
@inject IDbContextFactory<Plan2GatherContext> DbFactory

<PageTitle>Users</PageTitle>

<h1>Users</h1>

<div><input type="search" @bind="filter" @bind:event="oninput"></div>

<p><a href="users/create">Make new</a></p>

<div>
    <QuickGrid Class="table" Items="FilteredUsers" Pagination="pagination">
        <PropertyColumn Property="user => user.UserId" Sortable="true" Title="ID" />
        <PropertyColumn Property="user => user.UserName" Sortable="true" Title="Username" />
        <PropertyColumn Property="user => user.UserType" Sortable="true" Title="Account Type" />
        <PropertyColumn Property='user => user.Email ?? "None"' Sortable="true" Title="Email" />

        <TemplateColumn Context="user">
            <a href="@($"users/edit?id={user.UserId}")">Edit</a>
            <a href="@($"users/details?id={user.UserId}")">Details</a>
            <a href="@($"users/delete?id={user.UserId}")">Delete</a>
        </TemplateColumn>
    </QuickGrid>
</div>

<Paginator State="pagination" />

@code {
    private Plan2GatherContext context = default!;
    private PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    private string filter = string.Empty;
    private IQueryable<Plan2Gather.Models.User> FilteredUsers => context.Users.Where(u => u.UserName.Contains(filter));
    protected override void OnInitialized() => context = DbFactory.CreateDbContext();
    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}