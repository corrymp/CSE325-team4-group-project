@page "/availabilities/delete"
@using Microsoft.EntityFrameworkCore
@using Plan2Gather.Models
@inject IDbContextFactory<Plan2Gather.Data.Plan2GatherContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Availability</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this availability?</p>

<div>
    <h2>Availability</h2>
    <hr>
    @if (availability is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">Event ID</dt>
            <dd class="col-sm-10">@availability.EventId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">User ID</dt>
            <dd class="col-sm-10">@availability.UserId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Encoded availability string</dt>
            <dd class="col-sm-10">@availability.Times</dd>
        </dl>
        <EditForm method="post" Model="availability" OnValidSubmit="DeleteAvailability" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(availability is null)">Delete</button> |
            <a href="/availabilities">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Availability? availability;
    [SupplyParameterFromQuery] private int User { get; set; }
    [SupplyParameterFromQuery] private int Event { get; set; }
    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        availability = await context.Availabilities.FirstOrDefaultAsync(a => a.EventId == Event && a.UserId == User);
        if (availability is null) NavigationManager.NotFound();
    }
    private async Task DeleteAvailability()
    {
        using var context = DbFactory.CreateDbContext();
        context.Availabilities.Remove(availability!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/availabilities");
    }
}