@page "/events/delete"
@using Microsoft.EntityFrameworkCore
@using Plan2Gather.Models
@inject IDbContextFactory<Plan2Gather.Data.Plan2GatherContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this event?</p>

<div>
    <h2>Event</h2>
    <hr>
    @if (evnt is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">ID</dt>
            <dd class="col-sm-10">@evnt.EventId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Event name</dt>
            <dd class="col-sm-10">@evnt.EventName</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Organizer ID</dt>
            <dd class="col-sm-10">@evnt.OrganizerId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Start time</dt>
            <dd class="col-sm-10">@evnt.StartTime</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Dates</dt>
            <dd class="col-sm-10">@evnt.Dates</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Allows guest accounts?</dt>
            <dd class="col-sm-10">@(evnt.AllowGuests ? "Yes" : "No")</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Description</dt>
            <dd class="col-sm-10">@evnt.EventDescription</dd>
        </dl>
        <EditForm method="post" Model="evnt" OnValidSubmit="DeleteEvent" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(evnt is null)">Delete</button> |
            <a href="/events">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Event? evnt;
    [SupplyParameterFromQuery] private int Id { get; set; }
    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        evnt = await context.Events.FirstOrDefaultAsync(e => e.EventId == Id);
        if (evnt is null) NavigationManager.NotFound();
    }
    private async Task DeleteEvent()
    {
        using var context = DbFactory.CreateDbContext();
        context.Events.Remove(evnt!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/events");
    }
}