@page "/register_other"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Plan2Gather.Auth
@using Plan2Gather.Services
@using Plan2Gather.Models
@using System.Security.Cryptography.Xml
@inject NavigationManager Nav
@inject JwtAuthStateProvider AuthState
@inject ApiHttpClientFactory ApiFactory

<PageTitle>Register</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">Create a new account</h2>
                <hr />

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger" role="alert">@_error</div>
                }

                <EditForm FormName="register-form" Model="this" OnValidSubmit="HandleRegister">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <InputText
                            form="register-form"
                            id="username" 
                            class="form-control" 
                            placeholder="Username" 
                            @bind-value="_username" 
                            @bind-value:event="onchange"
                            maxlength="16" 
                        />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <InputText 
                            form="register-form"
                            id="password" 
                            class="form-control" 
                            type="password" 
                            placeholder="Password" 
                            @bind-value="_password" 
                            @bind-value:event="onchange"
                            required 
                        />
                    </div>

                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Confirm password</label>
                        <InputText 
                            form="register-form"
                            id="confirmPassword" 
                            class="form-control" 
                            type="password" 
                            placeholder="Confirm password" 
                            @bind-value="_confirmPassword" 
                            @bind-value:event="onchange"
                            required 
                        />
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email (optional — required to create events)</label>
                        <InputText 
                            form="register-form"
                            id="email" 
                            class="form-control" 
                            type="email" 
                            placeholder="Email" 
                            @bind-value="_email" 
                            @bind-value:event="onchange"
                        />
                    </div>

                    <button type="submit" form="register-form" class="btn btn-orange w-100">Register</button>

                    <div class="text-center mt-3">
                        <p>Already have an account? <a href="/login">Log in</a></p>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;
    private string _email = string.Empty;
    private User.UserTypes _accountType = User.UserTypes.BASIC;
    private string _error = string.Empty;
    private async Task HandleRegister()
    {
        _error = string.Empty;

        if(
            string.IsNullOrWhiteSpace(_username) &&
            string.IsNullOrWhiteSpace(_email)
        ){
            _error = "Please provide a username or email.";
            return;
        }

        // no username = use email as username
        if (string.IsNullOrWhiteSpace(_username)) _username = _email;

        if (_password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        // set account type to full if an email is provided, otherwise keep it as basic
        if (!string.IsNullOrWhiteSpace(_email)) _accountType = User.UserTypes.FULL;
        else _accountType = User.UserTypes.BASIC;

        try
        {
            var client = ApiFactory.Create();
            var payload = new RegisterRequest(
                _username, _password, _confirmPassword, 
                _accountType, string.IsNullOrWhiteSpace(_email) ? null : _email);
            var response = await client.PostAsJsonAsync("/api/auth/register", payload);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponse>();
                if (result is not null)
                {
                    await AuthState.SetTokenAsync(result.Token);
                    Nav.NavigateTo("/");
                }
            }
            else
            {
                _error = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            _error = $"Something went wrong: {ex.Message}";
        }
    }
}