@page "/register"

<PageTitle>Register</PageTitle>

<h1>Register</h1>

<section>
    <form method="post">
        <h2>Create a new account.</h2>
        <hr>
        <div class="text-danger" role="alert"></div>
        
        <fieldset><input 
            type="text" 
            id="username"
            name="username" 
            placeholder="username" 
            required
        >
        <label for="username">Username</label></fieldset>
        
        <fieldset><input 
            type="password" 
            id="password" 
            name="password" 
            required
        >
        <label for="password">Password</label></fieldset>

        <fieldset><input
            type="password" 
            id="confirmPassword"
            name="confirmPassword" 
        >
        <label for="remember">Confirm password</label></fieldset>

        <fieldset><input 
            type="email" 
            id="email"
            name="email" 
        >
        <label for="email">Email</label></fieldset>

        <button type="submit">Register</button>

        <fieldset><p>Already have an account? <a href="/login">Log in</a></p></fieldset>
    </form>
</section>

