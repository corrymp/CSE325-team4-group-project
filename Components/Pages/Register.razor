@page "/register"
@using System.Net.Http.Json
@using Plan2Gather.Auth
@using Plan2Gather.Services
@inject NavigationManager Nav
@inject JwtAuthStateProvider AuthState
@inject ApiHttpClientFactory ApiFactory

<PageTitle>Register</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">Create a new account</h2>
                <hr />

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger" role="alert">@_error</div>
                }

                <form id="registerForm" @onsubmit="HandleRegister">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" id="username" class="form-control" @bind="_username" @bind:event="oninput" required />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" id="password" class="form-control" @bind="_password" @bind:event="oninput" required />
                    </div>

                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Confirm Password</label>
                        <input type="password" id="confirmPassword" class="form-control" @bind="_confirmPassword" @bind:event="oninput" required />
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email (optional)</label>
                        <input type="email" id="email" class="form-control" @bind="_email" @bind:event="oninput" />
                    </div>

                    <div class="mb-3">
                        <label for="accType" class="form-label">Account Type</label>
                        <select id="accType" class="form-select" @bind="_accountType" @bind:event="onchange" required>
                            <option value="" disabled selected>Select...</option>
                            <option value="FULL">Organizer</option>
                            <option value="BASIC">User</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-orange w-100">Register</button>

                    <div class="text-center mt-3">
                        <p>Already have an account? <a href="/login">Log in</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@code {
    private string _username = "";
    private string _password = "";
    private string _confirmPassword = "";
    private string _email = "";
    private string _accountType = "";
    private string _error = "";

    private async Task HandleRegister()
    {
        _error = "";

        // Validation
        if (string.IsNullOrWhiteSpace(_username))
        {
            _error = "Username is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_password))
        {
            _error = "Password is required.";
            return;
        }
        if (_password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_accountType))
        {
            _error = "Please select an account type.";
            return;
        }

        try
        {
            var client = ApiFactory.Create();
            var payload = new RegisterRequest(_username, _password, _confirmPassword, _accountType,
                                              string.IsNullOrWhiteSpace(_email) ? null : _email);
            var response = await client.PostAsJsonAsync("/api/auth/register", payload);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponse>();
                if (result is not null)
                {
                    await AuthState.SetTokenAsync(result.Token);
                    Nav.NavigateTo("/");
                }
            }
            else
            {
                _error = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            _error = $"Something went wrong: {ex.Message}";
        }
    }
}