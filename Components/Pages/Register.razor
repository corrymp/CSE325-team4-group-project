@page "/register"
@using System.Net.Http.Json
@using Plan2Gather.Auth
@using Plan2Gather.Services
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager Nav
@inject JwtAuthStateProvider AuthState
@inject ApiHttpClientFactory ApiFactory
@rendermode InteractiveServer

<PageTitle>Register</PageTitle>

<section class="auth-section">
    <EditForm Model="this" FormName="registerForm" OnSubmit="HandleRegister">
        <h2>Create a new account</h2>
        <hr />

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="text-danger" role="alert">@_error</div>
        }

        <fieldset>
            <input type="text"
                   id="username"
                   placeholder="Username"
                   @bind="_username"
                   maxlength="16"
                   required />
            <label for="username">Username</label>
        </fieldset>

        <fieldset>
            <input type="password"
                   id="password"
                   placeholder="Password"
                   @bind="_password"
                   required />
            <label for="password">Password</label>
        </fieldset>

        <fieldset>
            <input type="password"
                   id="confirmPassword"
                   placeholder="Confirm password"
                   @bind="_confirmPassword"
                   required />
            <label for="confirmPassword">Confirm Password</label>
        </fieldset>

        <fieldset>
            <input type="email"
                   id="email"
                   placeholder="Email (optional — required for FULL account)"
                   @bind="_email" />
            <label for="email">Email</label>
        </fieldset>

        <fieldset>
            <select name="accType" id="accType" @bind="_accountType">
                <option value="" disabled>Select...</option>
                <option value="FULL">Organizer</option>
                <option value="BASIC">User</option>
            </select>
            <label for="accType">Account Type</label>
        </fieldset>

        <button type="submit">Register</button>

        <fieldset>
            <p>Already have an account? <a href="/login">Log in</a></p>
        </fieldset>
    </EditForm>
</section>

@code {
    private string _username = "";
    private string _password = "";
    private string _confirmPassword = "";
    private string _email = "";
    private string _accountType = "";
    private string _error = "";

    private async Task HandleRegister()
    {
        Console.WriteLine("REGISTER CLICKED");
        _error = "";

        if (_password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_accountType))
        {
            _error = "Please select an account type.";
            return;
        }
        try
        {
            var client = ApiFactory.Create();
            var payload = new RegisterRequest(_username, _password, _confirmPassword, _accountType, string.IsNullOrWhiteSpace(_email) ? null : _email);
            var response = await client.PostAsJsonAsync("/api/auth/register", payload);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponse>();
                if (result is not null)
                {
                    await AuthState.SetTokenAsync(result.Token);
                    Nav.NavigateTo("/");
                }
            }
            else
            {
                _error = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            _error = $"Something went wrong: {ex.Message}";
        }
    }
}
