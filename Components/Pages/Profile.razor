@page "/profile"
@rendermode InteractiveServer
@using System.Security.Claims
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Plan2Gather.Auth
@using Plan2Gather.Services
@inject JwtAuthStateProvider AuthState
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@inject ApiHttpClientFactory ApiFactory
@inject IJSRuntime JS

<PageTitle>My Profile</PageTitle>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <h2 class="card-title text-center mb-4">My Profile</h2>
                    <hr />

                    @if (_user is not null)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">Username</label>
                            <p class="form-control-plaintext">@_user.Identity?.Name</p>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <p class="form-control-plaintext">@_email</p>
                        </div>
                        <div class="d-flex gap-2 justify-content-between">
                            <a href="/events/create" class="btn btn-primary">+ Create New Event</a>
                            <button class="btn btn-danger" @onclick="Logout">Logout</button>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">You are not logged in. <a href="/login">Login here</a></div>
                    }
                </div>
            </div>

            @if (_user is not null)
            {
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h3 class="mb-3">My Events</h3>
                        <hr />
                        @if (_myEvents == null)
                        {
                            <p>Loading...</p>
                        }
                        else if (!_myEvents.Any())
                        {
                            <p>You haven't created any events yet. <a href="/events/create">Create one now</a>.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Event Name</th>
                                            <th>Start Date</th>
                                            <th>Duration (hours)</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ev in _myEvents)
                                        {
                                            <tr>
                                                <td>@ev.EventName</td>
                                                <td>@ev.StartTime.ToLocalTime().ToString("g")</td>
                                                <td>@ev.Duration</td>
                                                <td>
                                                    <a href="/event/@ev.EventId" class="btn btn-sm btn-info">View</a>
                                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteEvent(ev.EventId)">Delete</button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private ClaimsPrincipal? _user;
    private string _email = "Not provided";
    private List<UserEventDto>? _myEvents;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        _user = authState.User;
        
        var emailClaim = _user?.FindFirst(ClaimTypes.Email) ?? _user?.FindFirst("email");
        if (emailClaim != null && !string.IsNullOrEmpty(emailClaim.Value))
            _email = emailClaim.Value;
        
        if (_user?.Identity?.IsAuthenticated == true)
        {
            await LoadMyEvents();
        }
    }

    private async Task LoadMyEvents()
    {
        var token = await AuthState.GetTokenAsync();
        if (string.IsNullOrEmpty(token)) return;
        
        var client = ApiFactory.Create();
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        
        try
        {
            _myEvents = await client.GetFromJsonAsync<List<UserEventDto>>("/api/events/user/me");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading events: {ex.Message}");
            _myEvents = new List<UserEventDto>();
        }
        StateHasChanged();
    }

    private async Task DeleteEvent(int eventId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this event?");
        if (!confirmed) return;
        
        var token = await AuthState.GetTokenAsync();
        if (string.IsNullOrEmpty(token)) return;
        
        var client = ApiFactory.Create();
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        
        var response = await client.DeleteAsync($"/api/events/{eventId}");
        if (response.IsSuccessStatusCode)
        {
            await LoadMyEvents();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Delete failed: {error}");
        }
    }

    private async Task Logout()
    {
        await AuthState.SetTokenAsync(null);
        Nav.NavigateTo("/", true);
    }

    private record UserEventDto(int EventId, string EventName, DateTime StartTime, int Duration);
}