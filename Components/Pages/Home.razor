@page "/"

@using System.Diagnostics
@using Plan2Gather.Models

<PageTitle>Plan2Gather - Find the perfect time, together</PageTitle>

<section>
    <hgroup>
        <h1>Stop guessing.</h1>
        <p>Start <span>gathering.</span></p>
    </hgroup>
    <p>
        Plan2Gather finds the perfect time for everyone.
        <br>
        Share the link, mark your availability,
        and let the grid show you exactly when your crew can meet.
    </p>
    <div>
        <a href="/register">Create Account</a>
    </div>
</section>

@inject CSE325_team4_group_project.Services.NotificationService NotificationService

<div class="m-3">
    <button class="btn btn-outline-success" @onclick="SimulateInvite">Simulate Invite Notification</button>
</div>

@code {
    private void SimulateInvite()
    {
        NotificationService.Add("Congratulations! You are invited to the meeting. I'll see you in 4 hours.");
    }
}

<hr>

<section>
    <h2>How it works</h2>
    <ol>
        <li>
            <h3>Create an event</h3>
            <p>Choose dates and time windows. Get a unique sharable link instantly.</p>
        </li>
        <li>
            <h3>Share the link</h3>
            <p>Send it to anyone - no account needed.</p>
        </li>
        <li>
            <h3>Find the best time</h3>
            <p>See overlapping availabilities and pick the perfect moment.</p>
        </li>
    </ol>
</section>

<section>
    <h2>Everything you need to plan</h2>
    <ul>
        <li>
            <h3>Visual Availability Grid</h3>
            <p>
                See at a glance when everyone is free.
                Color-coded overlap shows the best windows for your whole group.
            </p>
        </li>
        <li>
            <h3>Share with a Link</h3>
            <p>
                Send one link.
                Guests can respond without creating an account — your full team in one place, effortlessly.
            </p>
        </li>
        <li>
            <h3>Timezone Aware</h3>
            <p>
                Every attendee sees times in their own timezone.
                No more mental math or 3am scheduling mistakes.
            </p>
        </li>
        <li>
            <h3>Host Controls</h3>
            <p>As host, manage your guest list, remove unavailable attendees, and lock the final meeting time.</p>
        </li>
        <li>
            <h3>Smart Notifications</h3>
            <p>Get notified when the host finalizes the meeting time. No more refreshing the page wondering if it's decided.</p>
        </li>
        <li>
            <h3>Your Events Dashboard</h3>
            <p>Track every event you've created or joined. See pending responses, finalized times, and meeting details in one view.</p>
        </li>
    </ul>
</section>

<div>
    <a href="/register">Create your Free Account</a>
</div>

