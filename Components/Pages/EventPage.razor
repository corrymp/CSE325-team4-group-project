@page "/event/{EventId:int}"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using System.Security.Claims
@using Plan2Gather.Auth
@using Plan2Gather.Services
@inject NavigationManager Nav
@inject ApiHttpClientFactory ApiFactory
@inject JwtAuthStateProvider AuthState
@inject IJSRuntime JS

<PageTitle>@_eventName</PageTitle>

<style>
    .matrices-container {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }
    .matrix-wrapper {
        flex: 1;
        min-width: 300px;
    }
    .availability-matrix {
        width: auto;
        margin-left: 0;
        font-size: 12px;
        border-collapse: collapse;
    }
    .availability-matrix td, .availability-matrix th {
        width: 40px;
        height: 40px;
        text-align: center;
        vertical-align: middle;
        padding: 2px;
        user-select: none;
        border: 1px solid #dee2e6;
    }
    .availability-matrix td {
        cursor: pointer;
    }
    .readonly-matrix td {
        cursor: default;
    }
    h4 {
        margin-top: 0;
    }
</style>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <div class="container">
        <h2>@_eventName</h2>
        @if (_isOrganizer)
        {
            <div class="alert alert-info">Organizer Controls</div>
            <div class="mb-3">
                <button class="btn btn-sm btn-secondary" @onclick="CopyInviteLink">Copy Invite Link</button>
                <button class="btn btn-sm btn-secondary" @onclick="ExportToSpreadsheet">Export to Spreadsheet</button>
                <button class="btn btn-sm btn-secondary" @onclick="AddDummyUser">Add Dummy User</button>
            </div>
        }

        <div class="matrices-container">
            <!-- Left: User's own availability -->
            <div class="matrix-wrapper">
                <h4>Your Availability (click to toggle)</h4>
                <div style="overflow-x: auto;">
                    <table class="availability-matrix" id="userAvailabilityMatrix">
                        <thead>
                            <tr>
                                <th>Time / Day</th>
                                @foreach (var day in _days)
                                {
                                    <th>@day.Key.ToString()</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var hour in _hours)
                            {
                                <tr>
                                    <th>@hour</th>
                                    @foreach (var day in _days)
                                    {
                                        if (_slotMap.ContainsKey(day.Key) && _slotMap[day.Key].ContainsKey(hour))
                                        {
                                            var slot = _slotMap[day.Key][hour];
                                            var isSelected = _currentUserAvailabilities.Contains(slot.Id);
                                            <td data-slot-id="@slot.Id"
                                                style="background-color: @(isSelected ? "#90EE90" : "#FFCCCC")"
                                                title="@GetUsersForSlot(slot.Id)">
                                                &nbsp;
                                            </td>
                                        }
                                        else
                                        {
                                            <td style="background-color: #f0f0f0;">&nbsp;</td>
                                        }
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Right: Collective availability -->
            <div class="matrix-wrapper">
                <h4>Overall Availability (hover to see who)</h4>
                <div style="overflow-x: auto;">
                    <table class="availability-matrix readonly-matrix" id="collectiveAvailabilityMatrix">
                        <thead>
                            <tr>
                                <th>Time / Day</th>
                                @foreach (var day in _days)
                                {
                                    <th>@day.Key.ToString()</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var hour in _hours)
                            {
                                <tr>
                                    <th>@hour</th>
                                    @foreach (var day in _days)
                                    {
                                        if (_slotMap.ContainsKey(day.Key) && _slotMap[day.Key].ContainsKey(hour))
                                        {
                                            var slot = _slotMap[day.Key][hour];
                                            var hasAnyUser = _slotUsers.ContainsKey(slot.Id) && _slotUsers[slot.Id].Count > 0;
                                            var users = GetUsersForSlot(slot.Id);
                                            <td style="background-color: @(hasAnyUser ? "#90EE90" : "#FFFFFF"); cursor: help;"
                                                title="@users">
                                                &nbsp;
                                            </td>
                                        }
                                        else
                                        {
                                            <td style="background-color: #f0f0f0;">&nbsp;</td>
                                        }
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int EventId { get; set; }

    private string _eventName = "";
    private bool _isOrganizer = false;
    private List<TimeSlotDto> _allSlots = new();
    private List<UserAttendanceDto> _attendancesByUser = new();
    private List<int> _currentUserAvailabilities = new();
    private int _currentUserId = 0;
    private bool _loading = true;
    private DotNetObjectReference<EventPage>? _dotNetRef;

    private Dictionary<DayOfWeek, string> _days = new();
    private List<string> _hours = new();
    private Dictionary<DayOfWeek, Dictionary<string, TimeSlotDto>> _slotMap = new();
    private Dictionary<int, List<string>> _slotUsers = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadEventData();
        await LoadCurrentUserAvailability();
        BuildMatrix();
        BuildSlotUsersMap();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("availabilityMatrix.init", _dotNetRef, "userAvailabilityMatrix", true);
            await JS.InvokeVoidAsync("availabilityMatrix.init", _dotNetRef, "collectiveAvailabilityMatrix", false);
        }
    }

    [JSInvokable]
    public async Task OnSelectionChanged(string[] slotIds)
    {
        if (slotIds.Length == 0) return;
        var slotId = int.Parse(slotIds[0]);
        Console.WriteLine($"Toggling slot {slotId}");

        if (_currentUserAvailabilities.Contains(slotId))
            _currentUserAvailabilities.Remove(slotId);
        else
            _currentUserAvailabilities.Add(slotId);

        await SaveAvailability();
        await LoadEventData();
        BuildSlotUsersMap();
        StateHasChanged();
    }

    private string GetUsersForSlot(int slotId)
    {
        if (_slotUsers.TryGetValue(slotId, out var users) && users.Count > 0)
            return string.Join(", ", users);
        return "No one available";
    }

    private void BuildSlotUsersMap()
    {
        _slotUsers = new Dictionary<int, List<string>>();
        foreach (var user in _attendancesByUser)
        {
            foreach (var slotId in user.AvailableSlotIds)
            {
                if (!_slotUsers.ContainsKey(slotId))
                    _slotUsers[slotId] = new List<string>();
                if (!_slotUsers[slotId].Contains(user.UserName))
                    _slotUsers[slotId].Add(user.UserName);
            }
        }
    }

    private async Task LoadEventData()
    {
        var token = await AuthState.GetTokenAsync();
        if (string.IsNullOrEmpty(token)) return;
        var client = ApiFactory.Create();
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

        var eventResp = await client.GetFromJsonAsync<EventDto>($"/api/events/{EventId}");
        if (eventResp != null)
        {
            _eventName = eventResp.Name;
            _isOrganizer = eventResp.IsOrganizer;
            _allSlots = eventResp.TimeSlots;
        }

        var attendancesResp = await client.GetFromJsonAsync<List<UserAttendanceDto>>($"/api/events/{EventId}/attendances");
        if (attendancesResp != null)
            _attendancesByUser = attendancesResp;
    }

    private async Task LoadCurrentUserAvailability()
    {
        _currentUserId = await GetCurrentUserId();
        var userEntry = _attendancesByUser.FirstOrDefault(u => u.UserId == _currentUserId);
        _currentUserAvailabilities = userEntry?.AvailableSlotIds.ToList() ?? new List<int>();
        Console.WriteLine($"Loaded {_currentUserAvailabilities.Count} saved slots for user {_currentUserId}");
    }

    private void BuildMatrix()
    {
        _days = _allSlots
            .GroupBy(s => s.DayOfWeek)
            .ToDictionary(g => g.Key, g => g.Key.ToString());

        _hours = _allSlots
            .Select(s => $"{s.StartTime}-{s.EndTime}")
            .Distinct()
            .OrderBy(h => h)
            .ToList();

        _slotMap = new Dictionary<DayOfWeek, Dictionary<string, TimeSlotDto>>();
        foreach (var day in _days.Keys)
        {
            _slotMap[day] = new Dictionary<string, TimeSlotDto>();
            foreach (var slot in _allSlots.Where(s => s.DayOfWeek == day))
            {
                var hourKey = $"{slot.StartTime}-{slot.EndTime}";
                _slotMap[day][hourKey] = slot;
            }
        }
    }

    private async Task<int> GetCurrentUserId()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier);
        return userIdClaim != null ? int.Parse(userIdClaim.Value) : 0;
    }

    private async Task SaveAvailability()
    {
        var token = await AuthState.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
        {
            Console.WriteLine("SaveAvailability: No token");
            return;
        }
        Console.WriteLine($"Saving {_currentUserAvailabilities.Count} slots to API");
        var client = ApiFactory.Create();
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        var response = await client.PostAsJsonAsync($"/api/events/{EventId}/attendance", new { AvailableSlotIds = _currentUserAvailabilities });
        Console.WriteLine($"Save response status: {response.StatusCode}");
        var responseBody = await response.Content.ReadAsStringAsync();
        Console.WriteLine($"Response body: {responseBody}");
    }

    private async Task CopyInviteLink()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Nav.BaseUri + $"event/{EventId}");
    }

    private async Task ExportToSpreadsheet()
    {
        var token = await AuthState.GetTokenAsync();
        if (string.IsNullOrEmpty(token)) return;
        var client = ApiFactory.Create();
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        await client.GetAsync($"/api/events/{EventId}/export");
    }

    private async Task AddDummyUser()
    {
        var token = await AuthState.GetTokenAsync();
        if (string.IsNullOrEmpty(token)) return;
        var client = ApiFactory.Create();
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        await client.PostAsync($"/api/events/{EventId}/dummy-user", null);
        await LoadEventData();
        await LoadCurrentUserAvailability();
        BuildMatrix();
        BuildSlotUsersMap();
        StateHasChanged();
    }

    private record EventDto(string Name, bool IsOrganizer, List<TimeSlotDto> TimeSlots);
    private record TimeSlotDto(int Id, DayOfWeek DayOfWeek, string StartTime, string EndTime);
    private record UserAttendanceDto(int UserId, string UserName, List<int> AvailableSlotIds);
}