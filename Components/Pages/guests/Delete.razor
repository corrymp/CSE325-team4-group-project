@page "/users/delete/guests"
@using Microsoft.EntityFrameworkCore
@using Plan2Gather.Models
@inject IDbContextFactory<Plan2Gather.Data.Plan2GatherContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Guest</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this guest?</p>

<div>
    <h2>Guest</h2>
    <hr>
    @if (guest is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">Event ID</dt>
            <dd class="col-sm-10">@guest.EventId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@guest.GuestName</dd>
        </dl>
        <EditForm method="post" Model="guest" OnValidSubmit="DeleteGuest" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(guest is null)">Delete</button> |
            <a href="/guests">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Guest? guest;
    [SupplyParameterFromQuery] private int Id { get; set; }
    [SupplyParameterFromQuery] private string Name { get; set; } = string.Empty;
    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        guest = await context.Guests.FirstOrDefaultAsync(g => g.EventId == Id && g.GuestName == Name);
        if (guest is null) NavigationManager.NotFound();
    }
    private async Task DeleteGuest()
    {
        using var context = DbFactory.CreateDbContext();
        context.Guests.Remove(guest!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/guests");
    }
}